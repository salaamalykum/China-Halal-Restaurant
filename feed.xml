---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml"/>
    <lastBuildDate>{{ site.lastmod | date_to_rfc822 }}</lastBuildDate>
    <language>zh-CN</language>
    {% for page in site.pages %}
    {% if page.layout == 'article' %}
    <item>
      <title>{{ page.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}{{ page.url }}</link>
      <guid isPermaLink="true">{{ site.url }}{{ site.baseurl }}{{ page.url }}</guid>
      <pubDate>{{ page.pub_date | default: page.lastmod | date_to_rfc822 }}</pubDate>
      {% if page.author %}<author>{{ page.author | xml_escape }}</author>{% endif %}
      <description>{{ page.title | xml_escape }}</description>
    </item>
    {% endif %}
    {% endfor %}
  </channel>
</rss>

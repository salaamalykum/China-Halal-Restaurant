---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
  {% unless page.url contains '/assets/' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ page.url | remove: 'index.html' }}</loc>
    <lastmod>{{ page.lastmod | default: site.lastmod }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>{% if page.url == '/' or page.url == '/index.html' %}1.0{% elsif page.layout == 'article' %}0.8{% else %}0.5{% endif %}</priority>
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
